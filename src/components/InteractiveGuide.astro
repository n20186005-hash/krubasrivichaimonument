---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
---

<section id="interactive-guide" class="py-16 bg-ivory text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-10">
      <h2 class="font-display font-semibold text-3xl md:text-4xl text-teak">交互式参拜指南</h2>
      <p class="mt-3 text-ink/70">点击各面查看对应的祈求主题与参拜要点</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <!-- Interactive Map -->
      <div class="relative w-full max-w-sm mx-auto aspect-square bg-teak/5 rounded-full border-2 border-dashed border-gold/30 flex items-center justify-center mt-8">
        <!-- Center Shrine -->
        <div class="absolute w-24 h-24 bg-gold rounded-sm rotate-45 flex items-center justify-center shadow-lg z-10">
          <span class="text-teak font-bold -rotate-45">神坛</span>
        </div>
        
        <!-- 4 Faces Buttons -->
        <!-- Front: Bottom (since entrance is usually at the bottom of the map) -->
        <button class="face-btn absolute -bottom-6 left-1/2 -translate-x-1/2 bg-gold text-white px-4 py-2 rounded-full hover:bg-goldBright transition-colors shadow-md whitespace-nowrap z-20" data-face="1">第一面 (正)</button>
        <!-- Second: Left (clockwise) -->
        <button class="face-btn absolute top-1/2 -left-8 -translate-y-1/2 bg-white border border-gold text-teak px-4 py-2 rounded-full hover:bg-gold hover:text-white transition-colors shadow-md whitespace-nowrap z-20" data-face="2">第二面 (顺时针)</button>
        <!-- Third: Top -->
        <button class="face-btn absolute -top-6 left-1/2 -translate-x-1/2 bg-white border border-gold text-teak px-4 py-2 rounded-full hover:bg-gold hover:text-white transition-colors shadow-md whitespace-nowrap z-20" data-face="3">第三面 (背)</button>
        <!-- Fourth: Right -->
        <button class="face-btn absolute top-1/2 -right-8 -translate-y-1/2 bg-white border border-gold text-teak px-4 py-2 rounded-full hover:bg-gold hover:text-white transition-colors shadow-md whitespace-nowrap z-20" data-face="4">第四面 (顺时针)</button>
        
        <div class="absolute inset-0 pointer-events-none rounded-full border-[16px] border-transparent border-t-gold/20 -rotate-45"></div>
        <span class="absolute top-[15%] left-[15%] text-xs text-gold/80 -rotate-45">↻ 顺时针绕行</span>
      </div>

      <!-- Info Card -->
      <div class="bg-white rounded-2xl p-6 md:p-8 shadow-xl border border-teak/10 min-h-[250px] mt-8 lg:mt-0">
        <h3 id="face-title" class="font-display text-2xl text-teak mb-4 border-b border-gold/20 pb-3">第一面（正面，正对大门）</h3>
        <div class="space-y-4">
          <div>
            <div class="text-xs uppercase tracking-wider text-gold font-semibold mb-1">祈求主题</div>
            <p id="face-theme" class="text-ink/85 font-medium text-lg">事业、学业、功名、官运</p>
          </div>
          <div>
            <div class="text-xs uppercase tracking-wider text-gold font-semibold mb-1">供品要求</div>
            <p id="face-offering" class="text-ink/85">3 支香、1 支蜡烛、1 串花环</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Offline Card Download -->
    <div class="mt-12 text-center">
      <a href="#" onclick="alert('即将下载离线游览与防骗指南...')" class="inline-flex items-center gap-2 bg-teak text-ivory px-6 py-3 rounded-full hover:bg-teakDeep transition-colors shadow-md">
        <span>📥 下载离线游览与防骗指南 (PDF)</span>
      </a>
      <p class="text-xs text-ink/50 mt-3">包含官方价目表、R-Walk 天桥路线图与公共守则，适合保存至手机离线查看。</p>
    </div>
  </div>
</section>

<script is:inline>
  const faceData = {
    '1': { title: '第一面（正面，正对大门）', theme: '事业、学业、功名、官运', offering: '3 支香、1 支蜡烛、1 串花环' },
    '2': { title: '第二面（顺时针）', theme: '姻缘、人际关系、感情、桃花', offering: '3 支香、1 支蜡烛、1 串花环' },
    '3': { title: '第三面（背面）', theme: '财富、正财偏财、投资、资产', offering: '3 支香、1 支蜡烛、1 串花环' },
    '4': { title: '第四面（顺时针）', theme: '健康、平安、家庭和谐、病愈', offering: '3 支香、1 支蜡烛、1 串花环' }
  };

  document.querySelectorAll('.face-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      // reset styles
      document.querySelectorAll('.face-btn').forEach(b => {
        b.classList.remove('bg-gold', 'text-white');
        b.classList.add('bg-white', 'text-teak');
      });
      // set active
      e.currentTarget.classList.remove('bg-white', 'text-teak');
      e.currentTarget.classList.add('bg-gold', 'text-white');
      
      const face = e.currentTarget.getAttribute('data-face');
      const data = faceData[face];
      if (data) {
        document.getElementById('face-title').textContent = data.title;
        document.getElementById('face-theme').textContent = data.theme;
        document.getElementById('face-offering').textContent = data.offering;
      }
    });
  });
</script>