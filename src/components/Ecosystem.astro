---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const r = messages.rituals;
---

<section id="rituals" class="py-20 bg-sand text-ink">
  <div class="max-w-7xl mx-auto px-5">
    <p class="font-hand text-gold text-xl md:text-2xl">{r.label}</p>
    <h2 class="font-display font-semibold text-3xl md:text-5xl text-teak mt-2">{r.heading}</h2>
    <blockquote class="border-l-4 border-gold pl-5 italic text-teak font-display text-xl my-6 max-w-3xl">“{r.quote}”</blockquote>
    <p class="max-w-3xl text-ink/85 leading-relaxed">{r.intro}</p>

    <!-- Worship steps -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{r.stepsTitle}</h3>
    <div class="grid md:grid-cols-2 gap-4">
      {r.steps.map((s) => (
        <div class="rounded-xl border border-gold/25 bg-white/50 p-5 flex gap-4">
          <span class="font-display text-3xl text-gold/70 leading-none">{s.order}</span>
          <div>
            <div class="font-semibold text-teak mb-1">{s.title}</div>
            <p class="text-sm text-ink/75 leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Offerings -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{r.offeringsTitle}</h3>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {r.offerings.map((o) => (
        <div class="rounded-2xl border border-gold/25 bg-white/40 p-5">
          <div class="font-display text-lg text-gold mb-2">{o.title}</div>
          <p class="text-sm text-ink/75 leading-relaxed">{o.desc}</p>
        </div>
      ))}
    </div>

    <!-- Dance troupes -->
    <div class="mt-12 rounded-2xl border border-gold/25 bg-teak/5 p-6">
      <h4 class="font-display text-xl text-teak mb-2">{r.danceTitle}</h4>
      <p class="text-sm text-ink/75 leading-relaxed">{r.dance}</p>
    </div>

    <!-- Etiquette tips -->
    <h3 class="font-display text-2xl text-teak mt-12 mb-4">{r.tipsTitle}</h3>
    <ul class="space-y-2 max-w-3xl text-sm text-ink/80">
      {r.tips.map((t) => (
        <li class="flex gap-2">
          <span class="text-gold mt-0.5" aria-hidden="true">•</span>
          <span>{t}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
