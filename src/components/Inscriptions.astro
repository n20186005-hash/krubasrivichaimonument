---
interface Props {
  messages: Record<string, any>;
}
const { messages } = Astro.props;
const data = messages.inscriptions;
if (!data) return null;
---

<section id="inscriptions" class="py-16 bg-teakDeep text-ivory">
  <div class="max-w-7xl mx-auto px-5">
    <div class="text-center mb-12">
      <p class="font-hand text-gold text-xl mb-2">铭文与经文</p>
      <h2 class="font-display font-semibold text-3xl md:text-4xl text-ivory">{data.label}</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-10">
      <!-- Part A: History Inscription -->
      <div class="space-y-6">
        <div class="bg-teak/60 border border-gold/20 rounded-2xl p-6 md:p-8">
          <h3 class="font-display text-2xl text-goldBright mb-4">{data.history.title}</h3>
          <ul class="space-y-4 text-ivory/85">
            <li class="flex gap-3">
              <span class="text-gold">📅</span>
              <span>{data.history.date}</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gold">👤</span>
              <span>{data.history.keyFigures}</span>
            </li>
            <li class="flex gap-3">
              <span class="text-gold">✨</span>
              <span>{data.history.meaning}</span>
            </li>
          </ul>
        </div>

        <div class="bg-gradient-to-br from-gold/15 to-teak/40 border border-gold/30 rounded-2xl p-6 md:p-8">
          <h3 class="font-display text-xl text-goldBright mb-3">{data.knowledge.title}</h3>
          <p class="text-sm text-ivory/80 leading-relaxed">{data.knowledge.text}</p>
        </div>
      </div>

      <!-- Part B: Sacred Chants -->
      <div class="bg-ivory text-ink rounded-2xl p-6 md:p-8 shadow-xl">
        <h3 class="font-display text-2xl text-teak mb-6 border-b border-teak/10 pb-4">{data.chants.title}</h3>
        
        <div class="space-y-8">
          {data.chants.steps.map((step: any) => (
            <div class="relative pl-6 border-l-2 border-gold/40">
              <div class="absolute -left-[9px] top-0 bg-gold w-4 h-4 rounded-full border-4 border-ivory"></div>
              <h4 class="font-bold text-teak mb-3">{step.step}</h4>
              
              <div class="bg-teak/5 rounded-lg p-4 space-y-3 font-medium">
                {step.pali && <div class="text-lg text-teak font-thai">{step.pali}</div>}
                {step.roman && <div class="text-sm text-ink/70 italic">{step.roman}</div>}
                {step.roman1 && <div class="text-sm text-ink/70 italic">{step.roman1}</div>}
                {step.roman2 && <div class="text-sm text-ink/70 italic">{step.roman2}</div>}
                {step.pronunciation && <div class="text-sm text-gold-700 bg-gold/10 inline-block px-2 py-1 rounded">🗣️ {step.pronunciation}</div>}
              </div>
              <p class="mt-3 text-sm text-ink/80 leading-relaxed"><strong>含义：</strong>{step.meaning}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>